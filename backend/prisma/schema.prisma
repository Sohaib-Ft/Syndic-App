// Schema Prisma — Gestion de Syndic d'Appartements (SQLite Version)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== MODÈLES ====================

model User {
  id            Int          @id @default(autoincrement())
  email         String       @unique
  password      String
  role          String       @default("RESIDENT") // "SYNDIC" | "RESIDENT"
  nom           String
  prenom        String
  telephone     String?
  typeResident  String?      @default("PROPRIETAIRE") // "PROPRIETAIRE" | "LOCATAIRE"
  actif         Boolean      @default(true)
  resetToken    String?
  resetTokenExpiry DateTime?
  mustChangePassword Boolean @default(false)
  googleId      String?      @unique
  authProvider  String       @default("local") // "local" | "google"
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  appartement   Appartement? @relation(fields: [appartementId], references: [id])
  appartementId Int?         @unique
  paiements     Paiement[]
  chargesPartielles ChargePartielleResident[]
  
  // Relation to link Resident to Syndic
  syndicId      Int?
  syndic        User?        @relation("SyndicResidents", fields: [syndicId], references: [id], onDelete: Cascade)
  residents     User[]       @relation("SyndicResidents")
  
  // Relation to link Syndic to other owned entities
  appartementsOwned Appartement[] @relation("SyndicAppartements")
  chargesOwned       Charge[]      @relation("SyndicCharges")
  chargesPartiellesOwned ChargePartielle[] @relation("SyndicChargePartielles")
}

model Appartement {
  id                Int          @id @default(autoincrement())
  numero            String
  etage             Int
  superficie        Float
  nbPieces          Int
  type              String?
  description       String?
  statut            String       @default("VACANT") // "OCCUPE" | "VACANT"
  chargesMensuelles Float        @default(0)
  resident          User?
  paiements         Paiement[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  syndicId          Int?
  syndic            User?        @relation("SyndicAppartements", fields: [syndicId], references: [id], onDelete: Cascade)

  @@unique([syndicId, numero])
}

model Paiement {
  id            Int            @id @default(autoincrement())
  montant       Float
  mois          Int
  annee         Int
  statut        String         @default("EN_ATTENTE") // "PAYE" | "EN_ATTENTE" | "EN_RETARD"
  datePaiement  DateTime?
  appartement   Appartement    @relation(fields: [appartementId], references: [id])
  appartementId Int
  resident      User           @relation(fields: [residentId], references: [id])
  residentId    Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@unique([appartementId, mois, annee])
}

model Charge {
  id          Int             @id @default(autoincrement())
  libelle     String
  montant     Float
  categorie   String          // "ENTRETIEN" | "ELECTRICITE" | "EAU" | "ASCENSEUR" | "NETTOYAGE" | "REPARATIONS" | "DIVERS"
  date        DateTime
  description String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  syndicId    Int?
  syndic      User?            @relation("SyndicCharges", fields: [syndicId], references: [id], onDelete: Cascade)
}

// Nouvelles charges pour les résidents
model ChargePartielle {
  id          Int             @id @default(autoincrement())
  libelle     String
  montant     Float
  date        DateTime
  description String?
  isGlobal    Boolean         @default(true)
  residents   ChargePartielleResident[]
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  syndicId    Int?
  syndic      User?            @relation("SyndicChargePartielles", fields: [syndicId], references: [id], onDelete: Cascade)
}

model ChargePartielleResident {
  id                Int             @id @default(autoincrement())
  chargePartielleId Int
  chargePartielle   ChargePartielle @relation(fields: [chargePartielleId], references: [id], onDelete: Cascade)
  residentId        Int
  resident          User            @relation(fields: [residentId], references: [id], onDelete: Cascade)
  statut            String          @default("EN_ATTENTE") // "PAYE" | "EN_ATTENTE"
  datePaiement      DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([chargePartielleId, residentId])
}

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}
